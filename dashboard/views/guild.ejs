<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atlas - Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-gray-100 font-sans flex min-h-screen flex-col md:flex-row">

  <!-- BARRA LATERAL (LISTA DE GUILDAS OU STATUS) -->
  <aside class="w-full md:w-80 bg-gray-900 border-r border-gray-800 p-6 flex flex-col justify-between">
    <div>
      <div class="mb-8">
        <h2 class="text-2xl font-black text-blue-500 tracking-wider">ATLAS PANEL</h2>
        <div class="mt-4 flex items-center gap-3 bg-gray-800/40 p-3 rounded-lg border border-gray-700/50">
          <div class="bg-blue-600 w-2.5 h-2.5 rounded-full animate-pulse"></div>
          <div>
            <p class="text-xs text-gray-400">Logado como</p>
            <p class="text-sm font-semibold text-white"><%= user.username %></p>
          </div>
        </div>
      </div>

      <!-- STATUS VIP / COMPRAR VIP -->
      <div class="bg-gradient-to-br from-yellow-500/10 to-amber-500/5 border border-yellow-500/20 p-4 rounded-xl mb-6">
        <h3 class="text-sm font-bold text-yellow-400 flex items-center gap-2">
          <span>👑</span> Membro VIP
        </h3>
        <% if (user.isVip) { %>
          <p class="text-xs text-gray-300 mt-1">Status: <span class="text-green-400 font-semibold">Ativo</span></p>
          <% if (user.vipExpiresAt) { %>
            <p class="text-[10px] text-gray-400">Validade: <%= new Date(user.vipExpiresAt).toLocaleDateString('pt-BR') %></p>
          <% } %>
        <% } else { %>
          <p class="text-xs text-gray-400 mt-1">Você está utilizando a versão gratuita (5 perguntas diárias de IA).</p>
          <a href="/checkout" class="mt-3 block text-center bg-yellow-500 hover:bg-yellow-600 text-gray-950 font-bold py-1.5 px-3 rounded text-xs transition">
            Obter Acesso Ilimitado
          </a>
        <% } %>
      </div>

      <!-- SELEÇÃO DE SERVIDORES -->
      <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Meus Servidores</h4>
      <div class="space-y-2">
        <% if (guilds && guilds.length > 0) { %>
          <% guilds.forEach(g => { %>
            <% if (g.botInGuild) { %>
              <a href="/dashboard/<%= g.id %>" class="flex items-center gap-3 p-2.5 rounded-lg hover:bg-gray-800/60 transition border border-transparent hover:border-gray-700/40">
                <% if (g.iconUrl) { %>
                  <img src="<%= g.iconUrl %>" class="w-8 h-8 rounded-full" alt="Icon">
                <% } else { %>
                  <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center font-bold text-xs"><%= g.name.substring(0,2) %></div>
                <% } %>
                <span class="text-sm font-medium text-gray-200"><%= g.name %></span>
              </a>
            <% } else { %>
              <div class="flex items-center justify-between p-2.5 rounded-lg opacity-50 bg-gray-900/50">
                <span class="text-sm text-gray-400"><%= g.name %></span>
                <a href="https://discord.com/api/oauth2/authorize?client_id=<%= process.env.CLIENT_ID %>&permissions=8&scope=bot%20applications.commands" target="_blank" class="text-[10px] bg-blue-600 hover:bg-blue-700 text-white font-bold px-2 py-1 rounded">Convidar</a>
              </div>
            <% } %>
          <% }) %>
        <% } else { %>
          <p class="text-xs text-gray-500">Nenhum servidor administrativo encontrado.</p>
        <% } %>
      </div>
    </div>

    <div class="mt-8 border-t border-gray-800 pt-4">
      <a href="/login" class="text-xs text-red-400 hover:underline">Sair da Conta</a>
    </div>
  </aside>

  <!-- ÁREA DE CONFIGURAÇÕES INDIVIDUAIS -->
  <main class="flex-1 p-6 md:p-12">
    <% if (activeGuild && config) { %>
      <div class="max-w-3xl">
        <div class="flex items-center gap-4 mb-8">
          <div class="bg-gray-800 p-3 rounded-xl border border-gray-700">
            <span class="text-2xl">⚙️</span>
          </div>
          <div>
            <h1 class="text-3xl font-extrabold text-white">Configurações de <%= activeGuild.name %></h1>
            <p class="text-sm text-gray-400">Personalize o comportamento do Atlas no seu servidor</p>
          </div>
        </div>

        <% if (success) { %>
          <div class="bg-emerald-500/10 border border-emerald-500 text-emerald-200 p-4 rounded-xl mb-6 text-sm">
            <%= success %>
          </div>
        <% } %>

        <form action="/dashboard/<%= activeGuild.id %>" method="POST" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- CANAL DE LOGS -->
            <div>
              <label class="block text-sm font-bold text-gray-300 mb-2">Canal de Auditoria (Logs)</label>
              <select name="logChannelId" class="w-full bg-gray-900 border border-gray-800 rounded-lg p-3 text-white focus:outline-none focus:border-blue-500">
                <option value="">Nenhum Canal Selecionado</option>
                <% channels.forEach(ch => { %>
                  <option value="<%= ch.id %>" <%= config.logChannelId === ch.id ? 'selected' : '' %>><%= ch.name %></option>
                <% }) %>
              </select>
            </div>

            <!-- LIMITE DE ADVERTÊNCIAS -->
            <div>
              <label class="block text-sm font-bold text-gray-300 mb-2">Limite Máximo de Avisos (Warns)</label>
              <input type="number" name="warnsLimit" value="<%= config.warnsLimit %>" min="1" max="10" class="w-full bg-gray-900 border border-gray-800 rounded-lg p-3 text-white focus:outline-none focus:border-blue-500">
            </div>

            <!-- CARGO DE STAFF -->
            <div>
              <label class="block text-sm font-bold text-gray-300 mb-2">Cargo de Staff (Acesso Administrativo)</label>
              <select name="staffRoleId" class="w-full bg-gray-900 border border-gray-800 rounded-lg p-3 text-white focus:outline-none focus:border-blue-500">
                <option value="">Nenhum Cargo Selecionado</option>
                <% roles.forEach(role => { %>
                  <option value="<%= role.id %>" <%= config.staffRoleId === role.id ? 'selected' : '' %>><%= role.name %></option>
                <% }) %>
              </select>
            </div>

            <!-- CARGO DE VERIFICADO -->
            <div>
              <label class="block text-sm font-bold text-gray-300 mb-2">Cargo de Verificado (Anti-Robô)</label>
              <select name="verifiedRoleId" class="w-full bg-gray-900 border border-gray-800 rounded-lg p-3 text-white focus:outline-none focus:border-blue-500">
                <option value="">Nenhum Cargo Selecionado</option>
                <% roles.forEach(role => { %>
                  <option value="<%= role.id %>" <%= config.verifiedRoleId === role.id ? 'selected' : '' %>><%= role.name %></option>
                <% }) %>
              </select>
            </div>

            <!-- CARGO DE VISITANTE -->
            <div>
              <label class="block text-sm font-bold text-gray-300 mb-2">Cargo de Visitante (Sem Verificação)</label>
              <select name="visitorRoleId" class="w-full bg-gray-900 border border-gray-800 rounded-lg p-3 text-white focus:outline-none focus:border-blue-500">
                <option value="">Nenhum Cargo Selecionado</option>
                <% roles.forEach(role => { %>
                  <option value="<%= role.id %>" <%= config.visitorRoleId === role.id ? 'selected' : '' %>><%= role.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="pt-4">
            <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-lg transition shadow-lg shadow-blue-600/20">
              Salvar Alterações
            </button>
          </div>
        </form>
      </div>
    <% } else { %>
      <div class="flex flex-col items-center justify-center h-full text-center">
        <span class="text-6xl mb-4">👈</span>
        <h2 class="text-2xl font-bold">Bem-vindo ao Atlas Dashboard!</h2>
        <p class="text-gray-400 mt-1 max-w-sm">Selecione um servidor na barra lateral esquerda para gerenciar canais de logs, limites de avisos e sistemas de captcha interativos.</p>
      </div>
    <% } %>
  </main>

</body>
</html>
